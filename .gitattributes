# Normalize line endings across Windows / macOS / Linux contributors.
# Without this, every Windows checkout produces a phantom diff because
# Windows uses CRLF and git stores LF. This file is the cure.

# Default: auto-detect text files, store as LF in the repo.
* text=auto eol=lf

# Source files - force LF in repo and on checkout.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.svg text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell / batch files keep their native endings.
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binaries - never touch these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
